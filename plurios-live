#!/bin/bash
# Author: @FershoUno

set -x			# run + debug
set -e                  # exit on error
set -o pipefail         # exit on pipeline error
set -u                  # treat unset variable as error

# === variables ===
SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
CONF_VAR="config/variables.conf"

. $CONF_VAR || exit 1

# === variables workspace ===
WORKSPACE="workspace"
ISO_DIR="$SCRIPT_DIR/$WORKSPACE/iso"
MNT_DIR="$SCRIPT_DIR/$WORKSPACE/mnt"
EXTRACT_DIR="$SCRIPT_DIR/$WORKSPACE/extract"
IMAGE_DIR="$SCRIPT_DIR/$WORKSPACE/image"
CUSTOM_DIR="$SCRIPT_DIR/$WORKSPACE/custom"
APT_DIR="$SCRIPT_DIR/apt-cache"

# === load plurioslib ===
. $CONF_PLURIOS || exit 1
. $CONF_CALAMARES || exit 1
. $LIB_PLURIOS || exit 1

# === main ===

function run(){
  get_content_iso
  load_filesystem
  repack_filesystem
  build_iso
}

if [[ "$(whoami)" != "root" ]]
then
	echo "You need to run plurios-live as root"
	exit 1
fi


ISO_FILE=$1
if ! [[ -n "$ISO_FILE" && -f "$ISO_FILE" && "${ISO_FILE##*.}" == "iso" ]]
then
    echo "Error: Use an existing file and it is in ISO format"
fi

echo "start: $(date)"
run
echo "end: $(date)"

#$1
