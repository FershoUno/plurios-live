#!/bin/bash

function setup_workspace(){
  mkdir -p $ISO_DIR $MNT_DIR $EXTRACT_DIR $CUSTOM_DIR $APT_DIR
}

function setup_isolinux_grub(){
  rm -f $EXTRACT_DIR/isolinux/live.cfg
  rm -f $EXTRACT_DIR/boot/grub/grub.cfg
  cp $SCRIPT_DIR/$BOOT_ISOLINUX_PLURIOS $EXTRACT_DIR/isolinux/
  cp $SCRIPT_DIR/$BOOT_GRUB_PLURIOS $EXTRACT_DIR/boot/grub/
}

function setup_chroot(){
  mount --bind /dev $CUSTOM_DIR/dev
  mount --bind /run $CUSTOM_DIR/run
  chroot $CUSTOM_DIR mount none -t proc /proc
  chroot $CUSTOM_DIR mount none -t sysfs /sys
  chroot $CUSTOM_DIR mount none -t devpts /dev/pts
}

function run_chroot(){
  chroot $CUSTOM_DIR bash -c 'for script in plurios/*; do bash "$script"; done'
  chroot $CUSTOM_DIR bash -c 'rm -rf /plurios'
}

function mount_iso(){
  mount -o loop $ISO_FILE $MNT_DIR
}

function umount_iso(){
  umount $MNT_DIR
}

function mount_apt(){
  mount --bind $APT_DIR $CUSTOM_DIR/var/cache/apt/archives
}

function umount_apt(){
  umount $CUSTOM_DIR/var/cache/apt/archives
}

function umount_chroot(){
  chroot $CUSTOM_DIR umount /proc
  chroot $CUSTOM_DIR umount /sys
  chroot $CUSTOM_DIR umount /dev/pts
  umount -l $CUSTOM_DIR/dev
  umount -l $CUSTOM_DIR/run
}

function copy_content_iso(){
  rsync -a "$MNT_DIR"/ $EXTRACT_DIR
}

function backup_squashfs(){
  if [ -f $EXTRACT_DIR/casper/filesystem.squashfs ]
  then
	mv $EXTRACT_DIR/casper/filesystem.squashfs $SCRIPT_DIR
  fi
}

function extract_content_filesystem(){
  if [ -f $SCRIPT_DIR/filesystem.squashfs ]
  then
 	unsquashfs -f -d $CUSTOM_DIR $SCRIPT_DIR/filesystem.squashfs
  elif [ -f $MNT_DIR/casper/filesystem.squashfs ]
  then
 	backup_squashfs
	extract_content_filesystem
  fi
}

function compress_content_filesystem(){
  mksquashfs $CUSTOM_DIR $EXTRACT_DIR/casper/filesystem.squashfs -comp $COMPRESSION -b 1024K -always-use-fragments -noappend -quiet -progress
}

function copy_dir_scripts(){
  cp -r $SCRIPT_DIR/config/plurios $CUSTOM_DIR/
}

function copy_branding_calamares(){
  rm -rf $CUSTOM_DIR/etc/calamares/branding
  cp -r $SCRIPT_DIR/config/core/branding $CUSTOM_DIR/etc/calamares/
  sed -i "s/PLURIOS_TITLE_INSTALLER/$PLURIOS_TITLE_INSTALLER/g" $CUSTOM_DIR/etc/calamares/branding/cinnamon-remix/branding.desc
  sed -i "s/PLURIOS_HELP_INSTALLER/$PLURIOS_HELP_INSTALLER/g" $CUSTOM_DIR/etc/calamares/branding/cinnamon-remix/branding.desc
  sed -i "s/PLURIOS_VERSION_INSTALLER/$PLURIOS_VERSION_INSTALLER/g" $CUSTOM_DIR/etc/calamares/branding/cinnamon-remix/branding.desc
  sed -i "s/PLURIOS_TITLE_CENTER_INSTALLER/$PLURIOS_TITLE_CENTER_INSTALLER/g" $CUSTOM_DIR/etc/calamares/branding/cinnamon-remix/branding.desc
  sed -i "s/PLURIOS_SHORT_VERSION_NAME_INSTALLER/$PLURIOS_SHORT_VERSION_NAME_INSTALLER/g" $CUSTOM_DIR/etc/calamares/branding/cinnamon-remix/branding.desc
  sed -i "s#PLURIOS_URL_ALL_INSTALLER#$PLURIOS_URL_ALL_INSTALLER#g" $CUSTOM_DIR/etc/calamares/branding/cinnamon-remix/branding.desc
}

