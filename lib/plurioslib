#!/bin/bash

function setup_workspace(){
  mkdir -p $ISO_DIR $MNT_DIR $EXTRACT_DIR $CUSTOM_DIR $APT_DIR
}

function setup_chroot(){
  mount --bind /dev $CUSTOM_DIR/dev
  mount --bind /run $CUSTOM_DIR/run
  chroot $CUSTOM_DIR mount none -t proc /proc
  chroot $CUSTOM_DIR mount none -t sysfs /sys
  chroot $CUSTOM_DIR mount none -t devpts /dev/pts
}

function umount_chroot(){
  chroot $CUSTOM_DIR umount /proc
  chroot $CUSTOM_DIR umount /sys
  chroot $CUSTOM_DIR umount /dev/pts
  umount -l $CUSTOM_DIR/dev
  umount -l $CUSTOM_DIR/run
}

function run_chroot(){
  chroot $CUSTOM_DIR bash -c 'for script in plurios/*; do bash "$script"; done'
  chroot $CUSTOM_DIR bash -c 'rm -rf /plurios'
}

function mount_iso(){
  mount -o loop $ISO_FILE $MNT_DIR
}

function umount_iso(){
  umount $MNT_DIR
}

function mount_apt(){
  mount --bind $APT_DIR $CUSTOM_DIR/var/cache/apt/archives
}

function umount_apt(){
  umount $CUSTOM_DIR/var/cache/apt/archives
}

function copy_content_iso(){
  rsync -a "$MNT_DIR"/ $EXTRACT_DIR
}

function extract_content_filesystem(){
  unsquashfs -f -d $CUSTOM_DIR $EXTRACT_DIR/casper/filesystem.squashfs
  rm -f $EXTRACT_DIR/casper/filesystem.squashfs
}

function compress_content_filesystem(){
  mksquashfs $CUSTOM_DIR $EXTRACT_DIR/casper/filesystem.squashfs -comp $COMPRESSION -Xcompression-level 19 -b 1024K -always-use-fragments -noappend -quiet -progress
}

function copy_dir_scripts(){
  cp -r $SCRIPT_DIR/config/plurios $CUSTOM_DIR/
}

function copy_branding_calamares(){
  rm -rf $CUSTOM_DIR/etc/calamares/branding
  cp -r $SCRIPT_DIR/config/core/branding $CUSTOM_DIR/etc/calamares/
  sed -i "s/PLURIOS_TITLE_INSTALLER/$PLURIOS_TITLE_INSTALLER/g" $CUSTOM_DIR/etc/calamares/branding/cinnamon-remix/branding.desc
  sed -i "s/PLURIOS_HELP_INSTALLER/$PLURIOS_HELP_INSTALLER/g" $CUSTOM_DIR/etc/calamares/branding/cinnamon-remix/branding.desc
  sed -i "s/PLURIOS_VERSION_INSTALLER/$PLURIOS_VERSION_INSTALLER/g" $CUSTOM_DIR/etc/calamares/branding/cinnamon-remix/branding.desc
  sed -i "s/PLURIOS_TITLE_CENTER_INSTALLER/$PLURIOS_TITLE_CENTER_INSTALLER/g" $CUSTOM_DIR/etc/calamares/branding/cinnamon-remix/branding.desc
  sed -i "s/PLURIOS_SHORT_VERSION_NAME_INSTALLER/$PLURIOS_SHORT_VERSION_NAME_INSTALLER/g" $CUSTOM_DIR/etc/calamares/branding/cinnamon-remix/branding.desc
  sed -i "s#PLURIOS_URL_ALL_INSTALLER#$PLURIOS_URL_ALL_INSTALLER#g" $CUSTOM_DIR/etc/calamares/branding/cinnamon-remix/branding.desc
}

function setup_isolinux_grub(){
  rm -f $EXTRACT_DIR/isolinux/live.cfg
  rm -f $EXTRACT_DIR/boot/grub/grub.cfg
  cp $SCRIPT_DIR/$BOOT_ISOLINUX_PLURIOS $EXTRACT_DIR/isolinux/
  cp $SCRIPT_DIR/$BOOT_GRUB_PLURIOS $EXTRACT_DIR/boot/grub/
}

function calculate_filesystem_size(){
  du -sx --block-size=1 $EXTRACT_DIR/casper/filesystem.squashfs | cut -f1 > $EXTRACT_DIR/casper/filesystem.size
}

function replace_the_filesystem_manifes_file(){
  rm -f $EXTRACT_DIR/casper/filesystem.manifest
  mv $CUSTOM_DIR/filesystem.manifest $EXTRACT_DIR/casper/
}

function update_vmlinuz(){
  rm -f $EXTRACT_DIR/boot/initrd.img
  rm -f $EXTRACT_DIR/boot/vmlinuz
  rm -f $EXTRACT_DIR/live/vmlinuz
  rm -f $EXTRACT_DIR/casper/initrd.img
  rm -f $EXTRACT_DIR/casper/vmlinuz

  cp $CUSTOM_DIR/boot/initrd.img $EXTRACT_DIR/boot/
  cp $CUSTOM_DIR/boot/initrd.img $EXTRACT_DIR/casper/

  cp $CUSTOM_DIR/boot/vmlinuz $EXTRACT_DIR/boot/
  cp $CUSTOM_DIR/boot/vmlinuz $EXTRACT_DIR/live/
  cp $CUSTOM_DIR/boot/vmlinuz $EXTRACT_DIR/casper/
}

function config_disk(){
  echo "PluriOS $VARIANT_ISO $VERSION_ISO" > $EXTRACT_DIR/.disk/info
  echo "$URL_SUPPORT" > $EXTRACT_DIR/.disk/release_notes_url
  echo '#define DISKNAME  plurios "Metadistro Boliviana PluriOS"' > $EXTRACT_DIR/README.diskdefines
  echo 'plurios "Metadistro Boliviana PluriOS"'  > $EXTRACT_DIR/.disk/info

  # remove mkisofs file
  rm -f $EXTRACT_DIR/.disk/mkisofs

  # remove packages from iso
  rm -rf $EXTRACT_DIR/{pool,preseed,dists}
}

function generate_iso(){
  xorriso -as mkisofs -iso-level 3 \
	-o $ISO_DIR/$NAME_ISO-$VARIANT_ISO-$VERSION_ISO-$ARCH_ISO.iso \
	-J -joliet-long \
	-r \
	-V "$NAME_ISO" \
	-b isolinux/isolinux.bin \
	-c isolinux/boot.cat \
	-no-emul-boot \
	-boot-load-size 4 \
	-boot-info-table \
	--eltorito-alt-boot \
	-e boot/grub/efi.img \
	-no-emul-boot \
	-isohybrid-gpt-basdat "$EXTRACT_DIR"
}

# ======= functions ======

function get_content_iso(){
  setup_workspace
  mount_iso
  copy_content_iso
}

function load_filesystem(){
 # backup_squashfs
  extract_content_filesystem
  setup_isolinux_grub
  setup_chroot
  mount_apt
  copy_dir_scripts
  run_chroot
}

function repack_filesystem(){
  umount_apt
  copy_branding_calamares
  replace_the_filesystem_manifes_file
  umount_chroot
  umount_iso
  update_vmlinuz
  compress_content_filesystem
  calculate_filesystem_size

  config_disk
}

function build_iso(){
  generate_iso
}
