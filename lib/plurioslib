function update_vmlinuz(){
  rm -f $EXTRACT_DIR/boot/initrd.img
  rm -f $EXTRACT_DIR/boot/vmlinuz
  rm -f $EXTRACT_DIR/live/vmlinuz
  rm -f $EXTRACT_DIR/casper/initrd.img
  rm -f $EXTRACT_DIR/casper/vmlinuz

  cp $CUSTOM_DIR/boot/initrd.img $EXTRACT_DIR/boot/
  cp $CUSTOM_DIR/boot/initrd.img $EXTRACT_DIR/casper/

  cp $CUSTOM_DIR/boot/vmlinuz $EXTRACT_DIR/boot/
  cp $CUSTOM_DIR/boot/vmlinuz $EXTRACT_DIR/live/
  cp $CUSTOM_DIR/boot/vmlinuz $EXTRACT_DIR/casper/
}


# ======= functions ======

function get_content_iso(){
  setup_workspace
  mount_iso
  copy_content_iso
}

function load_filesystem(){
  backup_squashfs
  extract_content_filesystem
  setup_isolinux_grub
  setup_chroot
  mount_apt
  copy_dir_scripts
  run_chroot
}

function repack_filesystem(){
  umount_apt
  copy_branding_calamares
  umount_chroot
  umount_iso
  update_vmlinuz
  compress_content_filesystem
}

function build_iso(){
  generate_iso
}
